set -e

# Check if clojure is already on the PATH.
if command -v clojure >/dev/null 2>&1; then
    exec clojure "$@"
fi

# Resolve the script directory
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
CLJW_DIR="${SCRIPT_DIR}/.cljw"
CLJW_BIN="${CLJW_DIR}/bin/clojure"
CLOJURE_CLI_URL="https://download.clojure.org/install/posix-install.sh"

# Install Clojure CLI if not present
if [ ! -x "$CLJW_BIN" ]; then
    mkdir -p "$CLJW_DIR"
    echo "Installing Clojure CLI to ${CLJW_DIR}..."
    curl -sL "$CLOJURE_CLI_URL" -o /tmp/clojure-install.sh
    sh /tmp/clojure-install.sh --prefix "$CLJW_DIR"
    rm /tmp/clojure-install.sh
fi

# Forward all arguments to the Clojure CLI
exec "$CLJW_BIN" "$@"
